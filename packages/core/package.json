{
  "name": "@beluga-icon/core",
  "version": "0.1.1",
  "description": "Shared types and utilities for Beluga Icon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepack": "npm run build",
    "test": "echo 'Tests run from monorepo root: npm test'"
  },
  "keywords": [
    "icon",
    "icons",
    "svg",
    "typescript",
    "beluga-icon"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fatihserhatturan/Power-Puff-Icon",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/fatihserhatturan/Power-Puff-Icon#readme",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^6.0.2"
  }
}
