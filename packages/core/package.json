{
  "name": "@power-puff/core",
  "version": "0.1.0",
  "description": "Shared types and utilities for Power Puff Icon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "prepack": "npm run build",
    "test": "echo 'Tests run from monorepo root: npm test'"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/power-puff-icon/power-puff-icon",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/power-puff-icon/power-puff-icon#readme",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  }
}
