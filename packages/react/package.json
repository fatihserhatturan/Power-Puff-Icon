{
  "name": "@power-puff/react",
  "version": "0.1.0",
  "description": "React icon components for Power Puff Icon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "LICENSE", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external react",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch --external react",
    "prepack": "npm run build",
    "test": "echo 'Tests run from monorepo root: npm test'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/power-puff-icon/power-puff-icon",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/power-puff-icon/power-puff-icon#readme",
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@power-puff/core": "*"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "icon",
    "icons",
    "react",
    "svg",
    "icon-library",
    "react-icons",
    "stroke-icons",
    "typescript",
    "power-puff"
  ],
  "license": "MIT"
}
