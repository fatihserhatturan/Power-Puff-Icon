{
  "name": "@beluga-icon/react",
  "version": "0.1.0",
  "description": "React icon components for Beluga Icon",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "size": "size-limit",
    "prepack": "npm run build",
    "test": "echo 'Tests run from monorepo root: npm test'"
  },
  "size-limit": [
    {
      "name": "full bundle (minified + brotli)",
      "path": "./dist/index.js",
      "limit": "500 kB"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/beluga-icon/beluga-icon",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/beluga-icon/beluga-icon#readme",
  "peerDependencies": {
    "react": ">=17.0.0"
  },
  "dependencies": {
    "@beluga-icon/core": "*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "tsup": "^8.3.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "icon",
    "icons",
    "react",
    "svg",
    "icon-library",
    "react-icons",
    "stroke-icons",
    "typescript",
    "beluga-icon"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
